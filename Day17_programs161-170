Program169_ReadUsingStreamReader.cs

```csharp
using System;
using System.IO;

class Program169_ReadUsingStreamReader
{
    static void Main()
    {
        using(StreamReader sr = new StreamReader("file.txt"))
        {
            string line;
            while((line = sr.ReadLine()) != null)
            {
                Console.WriteLine(line);
            }
        }
    }
}
