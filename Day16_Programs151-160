Program154_StackExample.cs

```csharp
using System;
using System.Collections.Generic;

class Program154_StackExample
{
    static void Main()
    {
        Stack<int> stack = new Stack<int>();

        stack.Push(10);
        stack.Push(20);
        stack.Push(30);

        Console.WriteLine("Top Element: " + stack.Peek());

        while(stack.Count > 0)
        {
            Console.WriteLine(stack.Pop());
        }
    }
}
```

