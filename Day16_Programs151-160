Program155_QueueExample.cs

```csharp
using System;
using System.Collections.Generic;

class Program155_QueueExample
{
    static void Main()
    {
        Queue<int> queue = new Queue<int>();

        queue.Enqueue(10);
        queue.Enqueue(20);
        queue.Enqueue(30);

        Console.WriteLine("Front Element: " + queue.Peek());

        while(queue.Count > 0)
        {
            Console.WriteLine(queue.Dequeue());
        }
    }
}
```

