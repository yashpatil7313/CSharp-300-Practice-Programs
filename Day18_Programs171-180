Program180_LINQAnyAll.cs

```csharp
using System;
using System.Linq;

class Program180_LINQAnyAll
{
    static void Main()
    {
        int[] arr = {2,4,6,8};

        bool anyOdd = arr.Any(x => x % 2 != 0);
        bool allEven = arr.All(x => x % 2 == 0);

        Console.WriteLine("Any Odd: " + anyOdd);
        Console.WriteLine("All Even: " + allEven);
    }
}
```

