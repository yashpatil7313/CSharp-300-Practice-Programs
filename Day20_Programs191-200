Program195_PrimeNumberChecker.cs

```csharp
using System;

class Program195_PrimeNumberChecker
{
    static void Main()
    {
        Console.Write("Enter number: ");
        int n = Convert.ToInt32(Console.ReadLine());

        bool isPrime = true;

        for(int i=2;i<=n/2;i++)
        {
            if(n % i == 0)
            {
                isPrime = false;
                break;
            }
        }

        Console.WriteLine(isPrime ? "Prime" : "Not Prime");
    }
}
```

