Program186_CheckAnagram.cs

```csharp
using System;
using System.Linq;

class Program186_CheckAnagram
{
    static void Main()
    {
        string s1 = "listen";
        string s2 = "silent";

        var a = s1.OrderBy(c => c);
        var b = s2.OrderBy(c => c);

        if(a.SequenceEqual(b))
            Console.WriteLine("Anagram");
        else
            Console.WriteLine("Not Anagram");
    }
}
```

