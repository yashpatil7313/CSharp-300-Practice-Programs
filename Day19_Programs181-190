Program185_StringFrequency.cs

```csharp
using System;

class Program185_StringFrequency
{
    static void Main()
    {
        string str = "aabbcc";

        foreach(char ch in str)
        {
            int count = 0;

            foreach(char c in str)
            {
                if(ch == c)
                    count++;
            }

            Console.WriteLine(ch + " = " + count);
        }
    }
}
```

