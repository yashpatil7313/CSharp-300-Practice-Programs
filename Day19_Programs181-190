using System;

class Program183_FindDuplicateCharacters
{
    static void Main()
    {
        string str = "programming";

        for(int i=0;i<str.Length;i++)
        {
            for(int j=i+1;j<str.Length;j++)
            {
                if(str[i] == str[j])
                {
                    Console.WriteLine(str[i]);
                    break;
                }
            }
        }
    }
}
